{
  "name": "pyrfor-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Pyrfor runtime workspace",
  "scripts": {
    "daemon": "tsx daemon/index.ts",
    "daemon:install": "tsx daemon/index.ts install",
    "daemon:uninstall": "tsx daemon/index.ts uninstall",
    "daemon:status": "tsx daemon/index.ts status",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm --filter @pyrfor/engine typecheck",
    "build": "pnpm --filter @pyrfor/engine build",
    "test": "pnpm --filter @pyrfor/engine test",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
