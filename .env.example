# ===========================================
# CEOClaw Local Development Environment
# ===========================================
# Copy this file to `.env` (and optionally `.env.local`) and replace the placeholder values with your own.

# ===========================================
# DATABASE (required)
# ===========================================

DATABASE_URL=postgresql://user:pass@host:5432/ceoclaw
DIRECT_URL=postgresql://user:pass@host:5432/ceoclaw

# ===========================================
# AUTH (required)
# ===========================================

NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# APP CONFIGURATION
# ===========================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CEOClaw
NEXT_PUBLIC_RELEASE_REPOSITORY=alexgrebeshok-coder/ceoclaw
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-javascript-api-key

# Optional explicit artifact URLs if you do not want to rely on the derived GitHub Release DMG URL
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=https://github.com/alexgrebeshok-coder/ceoclaw/releases/download/v1.0.0/CEOClaw_1.0.0_aarch64.dmg
# NEXT_PUBLIC_IOS_DOWNLOAD_URL=https://testflight.apple.com/join/your-link

# ===========================================
# AI PROVIDERS (choose at least one)
# ===========================================

OPENROUTER_API_KEY=sk-or-v1-your-key-here
# ZAI_API_KEY=your-zai-api-key-here
# OPENAI_API_KEY=sk-proj-your-key-here
DEFAULT_AI_PROVIDER=openrouter

# ===========================================
# BILLING / STRIPE
# ===========================================

ENABLE_USAGE_LIMITS=false
# STRIPE_SECRET_KEY=sk_live_or_test_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# STRIPE_PRICE_ID_STARTER=price_...
# STRIPE_PRICE_ID_BUSINESS=price_...
# STRIPE_PRICE_ID_TEAM=price_...

# ===========================================
# RETENTION / DELIVERY
# ===========================================

# EMAIL_FROM=noreply@ceoclaw.local
# EMAIL_DEFAULT_TO=team@ceoclaw.local
# SMTP_HOST=smtp.provider.local
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=smtp-user
# SMTP_PASSWORD=smtp-password
# TELEGRAM_DEFAULT_CHAT_ID=123456789
# CRON_SECRET=dev-cron-secret

# Optional manifest-driven integration layer
CEOCLAW_AI_PROVIDER_MANIFESTS='[]'
CEOCLAW_CONNECTOR_MANIFESTS='[]'

# Optional local AI gateway / MLX endpoint
NEXT_PUBLIC_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/v1/chat/completions
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/v1/chat/completions
# OPENCLAW_GATEWAY_TOKEN=optional-token
# SEOCLAW_AI_MODE=gateway

# ===========================================
# MONITORING
# ===========================================

LOG_LEVEL=info
# SENTRY_DSN=https://key@sentry.io/project
# NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project
# SENTRY_TRACES_SAMPLE_RATE=0.05
