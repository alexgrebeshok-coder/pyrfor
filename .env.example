# ============================================
# CEOClaw Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# APP MODE
# ============================================

# Demo mode - works without database (uses mock data)
# Set to "demo" for quick start, remove for production
APP_DATA_MODE=demo

# Skip authentication (for demo/development)
CEOCLAW_SKIP_AUTH=true

# ============================================
# AI PROVIDERS (choose one or more)
# ============================================

# AIJora (Рекомендуется для РФ - GPT-5, Grok 4, без VPN)
# Get key: https://www.aijora.ru/
AIJORA_API_KEY=your-aijora-key-here

# Polza.ai (Рекомендуется для РФ - 500+ моделей, оплата картами РФ)
# Get key: https://polza.ai
POLZA_API_KEY=pk_live-your-key-here

# Bothub (Резерв для РФ - корпоративные SLA, YandexGPT)
# Get key: https://bothub.chat
BOTHUB_API_KEY=bh_live-your-key-here

# OpenRouter (Глобальный - Gemini 3.1 Lite, fast & cheap)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ZAI - Russian AI provider (GLM-5)
# Get key: https://zai.com/
ZAI_API_KEY=your-zai-key-here

# OpenAI (GPT-5.2)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# AI Mode (optional, auto-detect if not set)
# Options: provider | mock | gateway
# SEOCLAW_AI_MODE=provider

# Default AI provider (optional)
# Priority: aijora → polza → openrouter → bothub → zai → openai
# DEFAULT_AI_PROVIDER=aijora

# ============================================
# DATABASE (optional - not needed for demo mode)
# ============================================

# Turso/libsql (Рекомендуется для продакшена - работает из РФ)
# Get credentials: https://turso.tech
# Create database: turso db create ceoclaw-prod
# Get URL: turso db show ceoclaw-prod
# Get token: turso db tokens create ceoclaw-prod
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# PostgreSQL (Neon, Supabase, etc.) - может не работать из РФ
# POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# POSTGRES_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# SQLite (for local development)
# DATABASE_URL="file:./dev.db"

# ============================================
# AUTHENTICATION (optional - not needed for demo mode)
# ============================================

# NextAuth.js Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
# Get from: https://console.cloud.google.com
# GOOGLE_CLIENT_ID=your-google-client-id-here
# GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# GitHub OAuth (optional)
# Get from: https://github.com/settings/developers
# GITHUB_CLIENT_ID=your-github-client-id-here
# GITHUB_CLIENT_SECRET=your-github-client-secret-here

# ============================================
# NOTIFICATIONS (optional)
# ============================================

# Telegram Bot Token (get from @BotFather)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# API Configuration
# DASHBOARD_API_KEY=your-secure-api-key-here

# ============================================
# OPENCLAW GATEWAY (optional - for advanced users)
# ============================================

# If you have OpenClaw Gateway running locally
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
