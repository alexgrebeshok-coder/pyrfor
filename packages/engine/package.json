{
  "name": "@pyrfor/engine",
  "version": "0.4.0-rc.1",
  "description": "Pyrfor Engine — open runtime core: Memory, Skills, Provider Router, MCP-server, Heartbeat, Tool Engine",
  "license": "Apache-2.0",
  "private": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ai": "./src/ai/index.ts",
    "./memory": "./src/memory/index.ts",
    "./orchestration": "./src/orchestration/index.ts",
    "./skills": "./src/skills/index.ts",
    "./auth": "./src/auth/index.ts",
    "./db": "./src/db/index.ts",
    "./utils": "./src/utils/index.ts",
    "./connectors": "./src/connectors/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./runtime/block-manifest": {
      "types": "./dist/runtime/block-manifest.d.ts",
      "default": "./dist/runtime/block-manifest.js"
    },
    "./runtime/block-memory-namespace": "./src/runtime/block-memory-namespace.ts",
    "./runtime/block-registry": "./src/runtime/block-registry.ts",
    "./runtime/block-loader": "./src/runtime/block-loader.ts",
    "./runtime/contract-registry": "./src/runtime/contract-registry.ts",
    "./runtime/release-readiness": {
      "types": "./dist/runtime/release-readiness.d.ts",
      "default": "./dist/runtime/release-readiness.js"
    },
    "./runtime/skill-importer": {
      "types": "./dist/runtime/skill-importer.d.ts",
      "default": "./dist/runtime/skill-importer.js"
    },
    "./runtime/sandbox": "./src/runtime/sandbox/index.ts"
  },
  "bin": {
    "pyrfor": "./bin/pyrfor.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "dist-cjs/",
    "src/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc --build && node scripts/postbuild.js",
    "prepublishOnly": "node scripts/prepublish-only.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --testTimeout=15000 --hookTimeout=15000",
    "dev": "tsc --build --watch"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@pyrfor/cli": "workspace:*",
    "@grammyjs/runner": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "better-sqlite3": "^12.9.0",
    "croner": "^10.0.1",
    "grammy": "^1.42.0",
    "mammoth": "^1.12.0",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.0.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1"
  }
}
