{
  "name": "@ceoclaw/engine",
  "version": "0.1.0",
  "description": "CEOClaw Engine — open core: Memory, Skills, Provider Router, MCP-server, Heartbeat, Tool Engine",
  "license": "Apache-2.0",
  "private": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ai": "./src/ai/index.ts",
    "./memory": "./src/memory/index.ts",
    "./orchestration": "./src/orchestration/index.ts",
    "./skills": "./src/skills/index.ts",
    "./auth": "./src/auth/index.ts",
    "./db": "./src/db/index.ts",
    "./utils": "./src/utils/index.ts",
    "./runtime": "./src/runtime/index.ts"
  },
  "bin": {
    "pyrfor": "./bin/pyrfor.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "dist-cjs/",
    "src/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc --build && node scripts/postbuild.js",
    "prepublishOnly": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --build --watch"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "grammy": "^1.42.0",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
