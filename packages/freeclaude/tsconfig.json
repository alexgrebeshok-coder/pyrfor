{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@ceoclaw/engine": ["../engine/src/index.ts"],
      "@ceoclaw/engine/*": ["../engine/src/*"]
    }
  },
  "references": [
    { "path": "../engine" }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx", "cli/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
