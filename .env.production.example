# ===========================================
# CEOClaw Production Environment Variables
# ===========================================
# Copy this file and fill in your values in Vercel Dashboard
# Project Settings → Environment Variables

# ===========================================
# AI PROVIDERS (at least one required)
# ===========================================

# OpenRouter API Key (recommended - Gemini 3.1 Lite)
# Get yours: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ZAI API Key (GLM-5)
# Get yours: https://open.bigmodel.cn/
ZAI_API_KEY=your-zai-api-key-here

# OpenAI API Key (optional - GPT-5.2)
# Get yours: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# ===========================================
# BILLING / STRIPE
# ===========================================

ENABLE_USAGE_LIMITS=true
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_BUSINESS=price_...
STRIPE_PRICE_ID_TEAM=price_...

# ===========================================
# RETENTION / DELIVERY
# ===========================================

EMAIL_FROM=noreply@ceoclaw.com
EMAIL_DEFAULT_TO=team@ceoclaw.com
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASSWORD=smtp-password
TELEGRAM_DEFAULT_CHAT_ID=123456789
CRON_SECRET=replace-with-a-strong-cron-secret

# ===========================================
# DATABASE (required - live-first runtime)
# ===========================================

# PostgreSQL URL (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require
POSTGRES_PRISMA_URL=postgresql://user:pass@host/db?sslmode=require
POSTGRES_URL=postgresql://user:pass@host/db?sslmode=require
# Optional non-pooling URL if your deployment needs it:
# POSTGRES_URL_NON_POOLING=postgresql://user:pass@host/db?sslmode=require

# APP_DATA_MODE is legacy and ignored in production; the runtime now validates that
# one of the above Postgres URLs is present before allowing traffic.

# ===========================================
# APP CONFIGURATION
# ===========================================

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# GitHub repository used to derive the desktop release download URL when one
# is not explicitly provided.
NEXT_PUBLIC_RELEASE_REPOSITORY=alexgrebeshok-coder/ceoclaw

# Optional explicit desktop / iPhone distribution URLs. If desktop is omitted,
# the app falls back to the GitHub Release DMG URL for the current version.
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=https://github.com/alexgrebeshok-coder/ceoclaw/releases/download/v1.0.0/CEOClaw_1.0.0_aarch64.dmg
# NEXT_PUBLIC_IOS_DOWNLOAD_URL=https://testflight.apple.com/join/your-link

# App Name
NEXT_PUBLIC_APP_NAME=CEOClaw

# NextAuth
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-app.vercel.app

# Default AI provider for production
DEFAULT_AI_PROVIDER=openrouter

# General log level
LOG_LEVEL=info

# NEVER set CEOCLAW_SKIP_AUTH=true in production

# ===========================================
# OPTIONAL INTEGRATIONS
# ===========================================

# Telegram Bot Token (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Telegram Chat ID (optional)
# TELEGRAM_CHAT_ID=-1001234567890

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=your-client-id
# GITHUB_CLIENT_SECRET=your-client-secret

# ===========================================
# MONITORING (optional)
# ===========================================

# Sentry DSN (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project
# Sentry DSN for server-side events (optional if same as public)
# SENTRY_DSN=https://key@sentry.io/project
# Sample rate for performance tracing (0-1)
# SENTRY_TRACES_SAMPLE_RATE=0.05

# Analytics ID (Google Analytics)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
