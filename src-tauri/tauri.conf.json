{
  "build": {
    "beforeBuildCommand": "npm run build:desktop-shell",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "./desktop-shell-dist"
  },
  "productName": "CEOClaw",
  "version": "1.0.0",
  "identifier": "com.ceoclaw.ceoclaw",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "height": 800,
        "width": 1200,
        "minHeight": 600,
        "minWidth": 800,
        "resizable": true,
        "title": "CEOClaw Dashboard",
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "Business",
    "copyright": "2026 CEOClaw",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "targets": "dmg",
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
