{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@pyrfor/engine": ["./packages/engine/src/index.ts"],
      "@pyrfor/engine/*": ["./packages/engine/src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "packages/engine/dist",
    "packages/engine/src/runtime/_archive/**",
    "packages/engine/src/**/*.test.ts",
    "packages/engine/src/**/*.spec.ts",
    "packages/engine/src/**/__tests__/**"
  ],
  "include": ["daemon/**/*.ts", "packages/engine/src/**/*.ts", "packages/engine/src/**/*.tsx"]
}
