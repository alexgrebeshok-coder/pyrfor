{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext", "es2015"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@ceoclaw/engine": ["./packages/engine/src/index.ts"],
      "@ceoclaw/engine/*": ["./packages/engine/src/*"],
      "@ceoclaw/business": ["./packages/business/src/index.ts"],
      "@ceoclaw/business/*": ["./packages/business/src/*"],
      "@ochag/family": ["./packages/ochag/src/index.ts"],
      "@ochag/family/*": ["./packages/ochag/src/*"],
      "@freeclaude/coder": ["./packages/freeclaude/src/index.ts"],
      "@freeclaude/coder/*": ["./packages/freeclaude/src/*"],
      "@ceoclaw/ui": ["./packages/ui/src/index.ts"],
      "@ceoclaw/ui/*": ["./packages/ui/src/*"]
    },
    "plugins": [{ "name": "next" }],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2015"
  },
  "exclude": ["node_modules", "prisma/**/*.ts", "lib/__tests__/**/*", "scripts", "packages/engine/src/runtime/_archive/**"],
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "packages/*/src/**/*.ts", "packages/*/src/**/*.tsx"]
}
