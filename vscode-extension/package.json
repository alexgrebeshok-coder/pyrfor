{
  "name": "pyrfor-vscode",
  "displayName": "Pyrfor",
  "description": "Pyrfor AI assistant for VSCode — connects to the local Pyrfor daemon.",
  "publisher": "pyrfor",
  "version": "0.4.0-rc.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pyrfor",
          "title": "Pyrfor",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "pyrfor": [
        {
          "type": "webview",
          "id": "pyrfor.chat",
          "name": "Chat"
        },
        {
          "id": "pyrfor.concepts",
          "name": "Concepts"
        },
        {
          "id": "pyrfor.approvals",
          "name": "Approvals"
        },
        {
          "type": "webview",
          "id": "pyrfor.trace",
          "name": "Concept Trace"
        }
      ]
    },
    "commands": [
      {
        "command": "pyrfor.connect",
        "title": "Pyrfor: Connect"
      },
      {
        "command": "pyrfor.disconnect",
        "title": "Pyrfor: Disconnect"
      },
      {
        "command": "pyrfor.openChat",
        "title": "Pyrfor: Open Chat"
      },
      {
        "command": "pyrfor.sendMessage",
        "title": "Pyrfor: Send Message"
      },
      {
        "command": "pyrfor.concept.start",
        "title": "Pyrfor: Start Universal Concept"
      },
      {
        "command": "pyrfor.concept.status",
        "title": "Pyrfor: Refresh Concepts"
      },
      {
        "command": "pyrfor.concept.abort",
        "title": "Pyrfor: Abort Concept"
      },
      {
        "command": "pyrfor.concept.openTrace",
        "title": "Pyrfor: Open Concept Trace"
      },
      {
        "command": "pyrfor.gateway.setToken",
        "title": "Pyrfor: Set Gateway Token"
      },
      {
        "command": "pyrfor.gateway.clearToken",
        "title": "Pyrfor: Clear Gateway Token"
      },
      {
        "command": "pyrfor.approvals.refresh",
        "title": "Pyrfor: Refresh Approvals"
      },
      {
        "command": "pyrfor.approval.approve",
        "title": "Pyrfor: Approve Request"
      },
      {
        "command": "pyrfor.approval.deny",
        "title": "Pyrfor: Deny Request"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pyrfor.concept.start",
          "when": "view == pyrfor.concepts",
          "group": "navigation"
        },
        {
          "command": "pyrfor.concept.status",
          "when": "view == pyrfor.concepts",
          "group": "navigation"
        },
        {
          "command": "pyrfor.approvals.refresh",
          "when": "view == pyrfor.approvals",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "pyrfor.concept.openTrace",
          "when": "view == pyrfor.concepts && viewItem =~ /pyrforConcept/",
          "group": "inline"
        },
        {
          "command": "pyrfor.concept.abort",
          "when": "view == pyrfor.concepts && viewItem == pyrforConcept",
          "group": "inline"
        },
        {
          "command": "pyrfor.approval.approve",
          "when": "view == pyrfor.approvals && viewItem == pyrforApproval",
          "group": "inline"
        },
        {
          "command": "pyrfor.approval.deny",
          "when": "view == pyrfor.approvals && viewItem == pyrforApproval",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Pyrfor",
      "properties": {
        "pyrfor.daemonUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:18790/",
          "description": "WebSocket URL of the Pyrfor daemon."
        },
        "pyrfor.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to the Pyrfor daemon on startup."
        },
        "pyrfor.gatewayUrl": {
          "type": "string",
          "default": "",
          "description": "Optional HTTP URL of the Pyrfor gateway used for Universal Engine concepts. Leave empty to derive it from pyrfor.daemonUrl. Use 'Pyrfor: Set Gateway Token' for bearer auth."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20",
    "@types/ws": "^8",
    "typescript": "^5",
    "vitest": "^1"
  },
  "dependencies": {
    "ws": "^8"
  }
}
