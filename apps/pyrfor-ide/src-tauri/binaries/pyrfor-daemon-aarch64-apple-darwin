#!/bin/sh
# pyrfor-daemon-aarch64-apple-darwin — Tauri externalBin launcher
#
# Tauri spawns this file directly.  It bootstraps the self-contained Node
# sidecar bundled alongside it:
#   _runtime/node             ← Node 22 binary
#   _runtime/libnode.*.dylib  ← libnode resolved via @loader_path
#   _app/bin/pyrfor.cjs       ← entry point (CJS bundle)
#
# Port discovery: the daemon writes a single line "LISTENING_ON=<port>" to
# stdout once it is ready.  The Rust sidecar manager reads this to find the
# actual port. Build smoke tests can set PYRFOR_PORT=0 explicitly; bundled
# Pyrfor.app otherwise uses runtime.json/default port 18790.
#
# NOTE: build-sidecar.sh rewrites bundled Node/Homebrew dylib references to
# @loader_path so the launcher never depends on /opt/homebrew or /usr/local.
#
# To populate _runtime/ and _app/ run:
#   bash apps/pyrfor-ide/scripts/build-sidecar.sh   (from repo root)
#   # or: cd apps/pyrfor-ide && npm run build:sidecar

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# In a bundled .app, the launcher lives in Contents/MacOS/ but the _runtime
# and _app dirs are copied to Contents/Resources/ via tauri.conf bundle.resources.
# In a dev/source layout, everything is co-located in binaries/.
if [ -x "$SCRIPT_DIR/_runtime/node" ]; then
  RES_DIR="$SCRIPT_DIR"
elif [ -x "$SCRIPT_DIR/../Resources/_runtime/node" ]; then
  RES_DIR="$(cd "$SCRIPT_DIR/../Resources" && pwd)"
else
  RES_DIR="$SCRIPT_DIR"
fi

NODE_BIN="$RES_DIR/_runtime/node"
APP_BIN="$RES_DIR/_app/bin/pyrfor.cjs"

if [ ! -x "$NODE_BIN" ]; then
  echo "ERROR: Node binary not found at $NODE_BIN — run 'bash apps/pyrfor-ide/scripts/build-sidecar.sh'" >&2
  exit 1
fi

if [ ! -f "$APP_BIN" ]; then
  echo "ERROR: pyrfor.cjs not found at $APP_BIN — run 'bash apps/pyrfor-ide/scripts/build-sidecar.sh'" >&2
  exit 1
fi

# Forward all caller arguments; default to --daemon (IDE sidecar: gateway + optional Telegram
# when telegram.enabled and bot token are set in ~/.pyrfor/runtime.json).
# Override with --telegram / --chat / --once / --ide explicitly if needed.
MODE_FLAG="--daemon"
for arg in "$@"; do
  case "$arg" in
    --telegram|--chat|--once|--daemon|--ide) MODE_FLAG="" ;;
  esac
done

PORT_ARGS=""
if [ "${PYRFOR_PORT+x}" = "x" ]; then
  PORT_ARGS="--port=$PYRFOR_PORT"
fi

exec "$NODE_BIN" "$APP_BIN" $MODE_FLAG $PORT_ARGS "$@"
