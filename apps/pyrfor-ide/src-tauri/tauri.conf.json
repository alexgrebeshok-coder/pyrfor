{
  "build": {
    "beforeBuildCommand": "cd .. && npm run build",
    "beforeDevCommand": "cd .. && npm run dev:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/dist"
  },
  "productName": "Pyrfor",
  "version": "0.1.0",
  "identifier": "dev.pyrfor.ide",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "height": 800,
        "width": 1200,
        "minHeight": 600,
        "minWidth": 800,
        "resizable": true,
        "title": "Pyrfor",
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "2026 Pyrfor",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "targets": "dmg",
    "externalBin": ["binaries/pyrfor-daemon"],
    "resources": {
      "binaries/_runtime": "_runtime",
      "binaries/_app": "_app"
    },
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/pyrfor-dev/pyrfor-ide/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDMzI2MEY5OURBODJFQjMKUldTekxxaWQrV0F5ekxWcmJSWlQ5dTFPaTgzOHVYZXZYa3VNVWh4S2lSUjJIQVFJMmEvZlZzTFgK"
    }
  }
}
