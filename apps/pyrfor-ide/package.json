{
  "name": "@pyrfor/ide",
  "version": "0.1.0",
  "private": true,
  "description": "Pyrfor IDE — Tauri desktop application",
  "scripts": {
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "build:web": "cd web && npm run build",
