generator businessClient {
  provider = "prisma-client-js"
  output   = "../node_modules/@ceoclaw/business-db"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

