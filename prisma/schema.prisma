generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AIProvider {
  id           String   @id
  name         String   @unique
  apiKey       String
  baseUrl      String?
  enabled      Boolean  @default(true)
  models       String
  defaultModel String?
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([enabled, priority])
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AgentSession {
  id        String    @id
  agentId   String
  status    String    @default("idle")
  task      String?
  result    String?
  model     String?
  provider  String?
  tokens    Int       @default(0)
  cost      Float     @default(0)
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  @@index([createdAt])
  @@index([agentId, status])
}

model AiRunLedger {
  id               String   @id
  origin           String
  agentId          String
  title            String
  status           String
  quickActionId    String?
  projectId        String?
  workflow         String?
  sourceEntityType String?
  sourceEntityId   String?
  inputJson        String
  runJson          String
  runCreatedAt     DateTime
  runUpdatedAt     DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([runCreatedAt])
  @@index([projectId])
  @@index([workflow])
  @@index([status, runUpdatedAt])
}

model AiApplyDecisionLedger {
  id                  String   @id
  runId               String
  proposalId          String
  proposalType        String
  idempotencyKey      String   @unique
  status              String
  operatorId          String?
  toolCallIdsJson     String
  resultJson          String
  errorMessage        String?
  compensationMode    String?
  compensationSummary String?
  executedAt          DateTime?
  failedAt            DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([runId, proposalId])
  @@index([runId, updatedAt])
  @@index([status, updatedAt])
}

model Board {
  id        String   @id
  name      String
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   Column[]

  @@index([projectId])
}

model Column {
  id        String   @id
  title     String
  order     Int      @default(0)
  color     String?
  boardId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([boardId, order])
  @@index([boardId])
}

model Communication {
  id        String   @id
  channel   String
  direction String
  message   String
  response  String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([channel, createdAt])
}

model ContextSnapshot {
  id        String   @id
  type      String
  projectId String?
  data      String
  tokens    Int      @default(0)
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model CutoverDecision {
  id                    String   @id
  workspaceId           String   @default("executive")
  tenantSlug            String
  decisionType          String
  summary               String
  details               String?
  warningId             String?
  warningLabel          String?
  readinessOutcome      String
  readinessOutcomeLabel String
  readinessGeneratedAt  DateTime
  reviewOutcome         String
  reviewOutcomeLabel    String
  reviewGeneratedAt     DateTime
  createdByUserId       String?
  createdByName         String?
  createdByRole         String?
  createdAt             DateTime @default(now())

  @@index([decisionType, createdAt])
  @@index([tenantSlug, createdAt])
  @@index([workspaceId, createdAt])
}

model DeliveryLedger {
  id                String    @id
  channel           String
  provider          String
  mode              String
  scope             String
  projectId         String?
  projectName       String?
  locale            String
  target            String?
  headline          String
  idempotencyKey    String    @unique
  scheduledPolicyId String?
  status            String
  retryPosture      String
  attemptCount      Int       @default(0)
  dryRun            Boolean   @default(false)
  providerMessageId String?
  contentHash       String
  requestJson       String
  responseJson      String?
  lastError         String?
  firstAttemptAt    DateTime?
  lastAttemptAt     DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([scheduledPolicyId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([status, updatedAt])
  @@index([channel, updatedAt])
}

model DerivedSyncState {
  key             String    @id
  status          String
  lastStartedAt   DateTime?
  lastCompletedAt DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  lastResultCount Int?
  metadataJson    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([lastSuccessAt])
  @@index([status, updatedAt])
}

model Document {
  id          String      @id
  title       String
  description String?
  filename    String
  url         String
  type        String
  size        Int?
  ownerId     String?
  projectId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner       TeamMember? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([type])
}

model EscalationItem {
  id              String    @id
  sourceType      String
  sourceRef       String?
  entityType      String
  entityRef       String
  projectId       String?
  projectName     String?
  title           String
  summary         String?
  purpose         String?
  urgency         String
  queueStatus     String    @default("open")
  sourceStatus    String
  ownerId         String?
  ownerName       String?
  ownerRole       String?
  firstObservedAt DateTime
  lastObservedAt  DateTime
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  slaTargetAt     DateTime
  metadataJson    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([sourceType, entityType, entityRef])
  @@index([slaTargetAt])
  @@index([ownerId])
  @@index([projectId])
  @@index([queueStatus, urgency])
}

model EvidenceRecord {
  id                 String    @id
  sourceType         String
  sourceRef          String?
  entityType         String
  entityRef          String
  projectId          String?
  title              String
  summary            String?
  observedAt         DateTime
  reportedAt         DateTime?
  confidence         Float
  verificationStatus String
  metadataJson       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([sourceType, entityType, entityRef])
  @@index([observedAt])
  @@index([projectId])
  @@index([entityType, entityRef])
  @@index([verificationStatus])
}

model Membership {
  id                   String                @id
  organizationId       String
  userId               String?
  teamMemberId         String?
  externalUserId       String?               @unique
  email                String?
  displayName          String
  role                 String                @default("MEMBER")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  teamMember           TeamMember?           @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceMemberships WorkspaceMembership[]

  @@index([userId])
  @@index([teamMemberId])
  @@index([organizationId, role])
}

model Memory {
  id         String    @id
  type       String
  category   String
  key        String
  value      String
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  confidence Float     @default(1.0)
  source     String    @default("user")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([key])
  @@index([type, category])
}

model Milestone {
  id          String   @id
  title       String
  description String?
  date        DateTime
  status      String   @default("upcoming")
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, date])
  @@index([projectId])
  @@index([status])
  @@index([date])
}

model Notification {
  id         String    @id
  userId     String
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([read])
  @@index([userId])
}

model Organization {
  id                   String       @id
  slug                 String       @unique
  name                 String
  description          String?
  billingPlan          String       @default("free")
  billingStatus        String       @default("active")
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?      @unique
  stripePriceId        String?
  trialEndsAt          DateTime?
  aiUsageToday         Int          @default(0)
  aiUsageResetAt       DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  memberships          Membership[]
  workspaces           Workspace[]

  @@index([billingStatus])
  @@index([createdAt])
}

model BillingEvent {
  id             String    @id
  type           String
  organizationId String?
  payloadJson    String
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([type, createdAt])
  @@index([organizationId, createdAt])
}

model PilotFeedback {
  id             String    @id
  targetType     String
  targetId       String
  targetLabel    String
  sourceLabel    String
  sourceHref     String?
  projectId      String?
  projectName    String?
  severity       String
  status         String    @default("open")
  summary        String
  details        String?
  ownerId        String?
  ownerName      String?
  ownerRole      String?
  reporterName   String?
  resolutionNote String?
  metadataJson   String?
  openedAt       DateTime  @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([ownerId, updatedAt])
  @@index([projectId, updatedAt])
  @@index([targetType, targetId, updatedAt])
  @@index([severity, status, updatedAt])
  @@index([status, updatedAt])
}

model PilotReviewDeliveryPolicy {
  id              String    @id
  workspaceId     String    @default("executive")
  channel         String    @default("email")
  recipient       String?
  timezone        String    @default("UTC")
  deliveryHour    Int
  deliveryWeekday Int       @default(1)
  active          Boolean   @default(true)
  createdByUserId String?
  updatedByUserId String?
  lastAttemptAt   DateTime?
  lastDeliveredAt DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([deliveryWeekday, deliveryHour, active])
  @@index([workspaceId, active])
}

model Project {
  id                            String                        @id
  name                          String
  description                   String?
  status                        String
  direction                     String
  priority                      String                        @default("medium")
  health                        String                        @default("good")
  start                         DateTime
  end                           DateTime
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
  budgetPlan                    Float?
  budgetFact                    Float?                        @default(0)
  progress                      Int                           @default(0)
  location                      String?
  latitude                      Float?
  longitude                     Float?
  workspaceId                   String                        @default("executive")
  boards                        Board[]
  documents                     Document[]
  evidenceRecords               EvidenceRecord[]
  equipment                     Equipment[]
  equipmentAssignments          EquipmentAssignment[]
  evmSnapshots                  EvmSnapshot[]
  expenses                      Expense[]
  contracts                     Contract[]
  materialMovements             MaterialMovement[]
  milestones                    Milestone[]
  risks                         Risk[]
  tasks                         Task[]
  telegramBriefDeliveryPolicies TelegramBriefDeliveryPolicy[]
  workReports                   WorkReport[]
  team                          TeamMember[]                  @relation("ProjectToTeamMember")

  @@index([status, health])
  @@index([status, priority])
  @@index([health])
  @@index([direction])
  @@index([status])
}

model ReconciliationCasefile {
  id                    String   @id
  key                   String   @unique
  caseType              String
  truthStatus           String
  resolutionStatus      String   @default("open")
  projectId             String?
  projectName           String?
  financeProjectId      String?
  title                 String
  explanation           String
  reasonCodesJson       String
  evidenceRecordIdsJson String
  fusionFactIdsJson     String
  telemetryRefsJson     String
  financeJson           String?
  fieldJson             String?
  telemetryJson         String?
  lastObservedAt        DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([lastObservedAt])
  @@index([caseType, updatedAt])
  @@index([projectId])
  @@index([truthStatus, updatedAt])
  @@index([resolutionStatus, updatedAt])
}

model Risk {
  id          String      @id
  title       String
  description String?
  category    String      @default("Прочие")
  probability String      @default("medium")
  impact      String      @default("medium")
  severity    Int         @default(3)
  status      String      @default("open")
  date        DateTime?
  ownerId     String?
  projectId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner       TeamMember? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([projectId, status, severity])
  @@index([projectId])
  @@index([category])
  @@index([severity])
  @@index([status])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Skill {
  id          String   @id
  name        String   @unique
  category    String
  description String
  prompt      String
  enabled     Boolean  @default(true)
  triggers    String?
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, enabled])
}

model Task {
  id                  String               @id
  title               String
  description         String?
  status              String               @default("todo")
  priority            String               @default("medium")
  order               Int                  @default(0)
  startDate           DateTime?
  dueDate             DateTime
  estimatedHours      Float?
  estimatedCost       Float?
  actualCost          Float?               @default(0)
  percentComplete     Int                  @default(0)
  parentTaskId        String?
  wbs                 String?
  isMilestone         Boolean              @default(false)
  isManualSchedule    Boolean              @default(false)
  constraintType      String?
  constraintDate      DateTime?
  completedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  projectId           String
  assigneeId          String?
  columnId            String?
  column              Column?              @relation(fields: [columnId], references: [id])
  assignee            TeamMember?          @relation(fields: [assigneeId], references: [id])
  parentTask          Task?                @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subtasks            Task[]               @relation("TaskHierarchy")
  baselines           TaskBaseline[]
  dependents          TaskDependency[]     @relation("TaskDependency_dependsOnTaskIdToTask")
  dependencies        TaskDependency[]     @relation("TaskDependency_taskIdToTask")
  expenses            Expense[]
  resourceAssignments ResourceAssignment[]
  timeEntries         TimeEntry[]

  @@index([projectId, startDate])
  @@index([projectId, status, dueDate])
  @@index([projectId, priority])
  @@index([projectId, dueDate])
  @@index([projectId, wbs])
  @@index([assigneeId, status])
  @@index([columnId])
  @@index([parentTaskId])
  @@index([projectId, status, order])
  @@index([projectId])
  @@index([dueDate])
  @@index([priority])
  @@index([status])
}

model TaskDependency {
  id              String   @id
  type            String   @default("FINISH_TO_START")
  taskId          String
  dependsOnTaskId String
  lagDays         Int      @default(0)
  createdAt       DateTime @default(now())
  dependsOnTask   Task     @relation("TaskDependency_dependsOnTaskIdToTask", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  task            Task     @relation("TaskDependency_taskIdToTask", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([dependsOnTaskId])
  @@index([taskId])
}

model TeamMember {
  id                  String               @id
  name                String
  initials            String?
  role                String
  email               String?
  avatar              String?
  capacity            Int                  @default(100)
  allocated           Int                  @default(50)
  hourlyRate          Float?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  documents           Document[]
  memberships         Membership[]
  resourceAssignments ResourceAssignment[]
  risks               Risk[]
  tasks               Task[]
  timeEntries         TimeEntry[]
  reviewedWorkReports WorkReport[]         @relation("WorkReport_reviewerIdToTeamMember")
  authoredWorkReports WorkReport[]         @relation("WorkReport_authorIdToTeamMember")
  projects            Project[]            @relation("ProjectToTeamMember")

  @@index([name, role])
  @@index([name])
}

model TelegramBriefDeliveryPolicy {
  id              String    @id
  workspaceId     String    @default("executive")
  scope           String
  projectId       String?
  locale          String    @default("ru")
  chatId          String?
  cadence         String    @default("daily")
  timezone        String    @default("UTC")
  deliveryHour    Int
  active          Boolean   @default(true)
  createdByUserId String?
  updatedByUserId String?
  lastAttemptAt   DateTime?
  lastDeliveredAt DateTime?
  lastMessageId   Int?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([deliveryHour, active])
  @@index([projectId])
  @@index([workspaceId, active])
}

model TenantOnboardingRunbook {
  id                    String    @id
  workspaceId           String    @default("executive")
  baselineTenantSlug    String
  baselineTenantLabel   String
  targetTenantSlug      String?
  targetTenantLabel     String?
  status                String    @default("draft")
  summary               String
  rolloutScope          String
  operatorNotes         String?
  handoffNotes          String?
  rollbackPlan          String?
  targetCutoverAt       DateTime?
  templateVersion       String    @default("tenant-rollout-v1")
  readinessOutcome      String
  readinessOutcomeLabel String
  readinessGeneratedAt  DateTime
  reviewOutcome         String
  reviewOutcomeLabel    String
  reviewGeneratedAt     DateTime
  latestDecisionType    String?
  latestDecisionLabel   String?
  latestDecisionSummary String?
  latestDecisionAt      DateTime?
  blockerCount          Int       @default(0)
  warningCount          Int       @default(0)
  createdByUserId       String?
  createdByName         String?
  createdByRole         String?
  updatedByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status, updatedAt])
  @@index([baselineTenantSlug, updatedAt])
  @@index([workspaceId, updatedAt])
}

model TimeEntry {
  id          String      @id
  taskId      String
  memberId    String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  description String?
  billable    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  member      TeamMember? @relation(fields: [memberId], references: [id])
  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([memberId, startTime])
  @@index([startTime])
  @@index([memberId])
  @@index([taskId])
}

model TaskBaseline {
  id             String   @id
  taskId         String
  baselineNumber Int      @default(0)
  startDate      DateTime
  finishDate     DateTime
  duration       Float?
  cost           Float?
  work           Float?
  createdAt      DateTime @default(now())
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, baselineNumber])
  @@index([taskId])
}

model EvmSnapshot {
  id        String   @id
  projectId String
  date      DateTime
  bac       Float
  pv        Float
  ev        Float
  ac        Float
  cpi       Float?
  spi       Float?
  eac       Float?
  tcpi      Float?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([projectId, date])
}

model Equipment {
  id                  String                @id
  name                String
  type                String
  model               String?
  serialNumber        String?
  status              String                @default("available")
  projectId           String?
  hourlyRate          Float?
  dailyRate           Float?
  location            String?
  latitude            Float?
  longitude           Float?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  project             Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  expenses            Expense[]
  assignments         EquipmentAssignment[]
  resourceAssignments ResourceAssignment[]

  @@index([status])
  @@index([projectId])
}

model EquipmentAssignment {
  id          String    @id
  equipmentId String
  projectId   String
  startDate   DateTime
  endDate     DateTime?
  hoursUsed   Float     @default(0)
  createdAt   DateTime  @default(now())
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([projectId, startDate])
}

model Material {
  id           String             @id
  name         String
  unit         String
  category     String
  currentStock Float              @default(0)
  minStock     Float              @default(0)
  unitPrice    Float?
  supplierId   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  supplier     Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements    MaterialMovement[]

  @@index([category])
}

model MaterialMovement {
  id          String   @id
  materialId  String
  projectId   String
  type        String
  quantity    Float
  unitPrice   Float?
  documentRef String?
  date        DateTime
  createdAt   DateTime @default(now())
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([materialId, date])
  @@index([projectId, date])
}

model Supplier {
  id          String     @id
  name        String
  inn         String?    @unique
  contactName String?
  phone       String?
  email       String?
  address     String?
  category    String?
  rating      Int?       @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expenses    Expense[]
  materials   Material[]
  contracts   Contract[]
}

model Contract {
  id          String   @id
  number      String
  title       String
  type        String
  supplierId  String
  projectId   String
  amount      Float
  paidAmount  Float    @default(0)
  currency    String   @default("RUB")
  startDate   DateTime
  endDate     DateTime
  status      String   @default("active")
  documentUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([supplierId])
  @@index([status])
}

model ExpenseCategory {
  id        String            @id
  name      String
  code      String            @unique
  icon      String?
  color     String?
  parentId  String?
  createdAt DateTime          @default(now())
  parent    ExpenseCategory?  @relation("ExpenseCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ExpenseCategory[] @relation("ExpenseCategoryTree")
  expenses  Expense[]
}

model Expense {
  id          String          @id
  projectId   String
  categoryId  String
  title       String
  description String?
  amount      Float
  currency    String          @default("RUB")
  date        DateTime
  status      String          @default("pending")
  documentUrl String?
  supplierId  String?
  taskId      String?
  equipmentId String?
  createdById String?
  oneCRef     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  equipment   Equipment?      @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  supplier    Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([categoryId])
  @@index([status])
  @@index([oneCRef])
}

model ResourceAssignment {
  id           String      @id
  taskId       String
  memberId     String?
  equipmentId  String?
  units        Float       @default(100)
  plannedHours Float?
  actualHours  Float?      @default(0)
  costRate     Float?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime    @default(now())
  task         Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member       TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  equipment    Equipment?  @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([memberId])
  @@index([equipmentId])
}

model User {
  id                 String          @id
  name               String?
  email              String?         @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  accounts           Account[]
  memberships        Membership[]
  sessions           Session[]
  preference         UserPreference?
  approvalsRequested Approval[]      @relation("ApprovalRequester")
  approvalsReviewed  Approval[]      @relation("ApprovalReviewer")

  @@index([email])
  @@index([createdAt])
}

model UserPreference {
  id                   String   @id
  userId               String   @unique
  workspaceId          String?
  compactMode          Boolean  @default(true)
  desktopNotifications Boolean  @default(true)
  soundEffects         Boolean  @default(false)
  emailDigest          Boolean  @default(true)
  aiResponseLocale     String   @default("ru")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WorkReport {
  id                         String      @id
  reportNumber               String      @unique
  projectId                  String
  authorId                   String
  reviewerId                 String?
  section                    String
  reportDate                 DateTime
  workDescription            String
  volumesJson                String      @default("[]")
  personnelCount             Int?
  personnelDetails           String?
  equipment                  String?
  weather                    String?
  issues                     String?
  nextDayPlan                String?
  attachmentsJson            String      @default("[]")
  status                     String      @default("submitted")
  reviewComment              String?
  source                     String      @default("manual")
  externalReporterTelegramId String?
  externalReporterName       String?
  submittedAt                DateTime    @default(now())
  reviewedAt                 DateTime?
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt
  reviewer                   TeamMember? @relation("WorkReport_reviewerIdToTeamMember", fields: [reviewerId], references: [id])
  author                     TeamMember  @relation("WorkReport_authorIdToTeamMember", fields: [authorId], references: [id])
  project                    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, reportDate])
  @@index([projectId, status, reportDate])
  @@index([projectId, reportDate])
  @@index([status])
  @@index([reportDate])
  @@index([reviewerId])
  @@index([authorId])
  @@index([projectId])
}

model Workspace {
  id                   String                @id
  organizationId       String
  key                  String
  name                 String
  initials             String
  description          String?
  isDefault            Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceMemberships WorkspaceMembership[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model WorkspaceMembership {
  id           String     @id
  workspaceId  String
  membershipId String
  role         String?
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, membershipId])
  @@index([membershipId])
}

model Approval {
  id            String    @id
  type          String // task_creation, risk_mitigation, budget_change, report_publish, ai_action
  entityType    String // task, risk, project, report, ai_run
  entityId      String?
  title         String
  description   String?
  status        String    @default("pending") // pending, approved, rejected, expired
  requestedById String?
  reviewedById  String?
  comment       String?
  metadata      String? // JSON string for type-specific data
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  expiresAt     DateTime?
  requestedBy   User?     @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy    User?     @relation("ApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([entityType, entityId])
}

// ─── Connector OAuth & Sync ────────────────────────────────────────────────

model ConnectorCredential {
  id             String    @id @default(cuid())
  workspaceId    String
  connectorId    String    // "google-calendar", "quickbooks", "xero", etc.
  provider       String    // OAuth provider: "google", "microsoft", "yandex", "intuit", "xero"
  accessToken    String    // encrypted at rest
  refreshToken   String?   // encrypted at rest
  tokenExpiresAt DateTime?
  scopes         String?   // comma-separated granted scopes
  accountLabel   String?   // user-visible label ("My Gmail", "Work QuickBooks")
  accountEmail   String?   // associated account email
  metadata       String?   // JSON string for provider-specific data (realm IDs, tenant IDs)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  syncEntries    ConnectorSyncEntry[]

  @@unique([workspaceId, connectorId])
  @@index([workspaceId])
  @@index([connectorId])
  @@index([provider])
}

model ConnectorSyncEntry {
  id               String    @id @default(cuid())
  credentialId     String
  direction        String    // "pull" | "push"
  entityType       String    // "calendar_events", "expenses", "invoices", "vendors"
  status           String    @default("running") // "running" | "completed" | "failed"
  recordsProcessed Int       @default(0)
  recordsFailed    Int       @default(0)
  error            String?
  syncToken        String?   // delta sync token for incremental fetches
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  credential       ConnectorCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, startedAt])
  @@index([status])
}

// ============================================
// Agent Message Bus Audit Log
// ============================================

model AgentMessage {
  id            String   @id
  type          String
  source        String
  target        String?
  payload       String   @default("{}")
  workspaceId   String?
  runId         String?
  correlationId String?
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
  @@index([source, createdAt])
  @@index([workspaceId, createdAt])
  @@index([runId])
}

model AIRunCost {
  id          String   @id @default(cuid())
  provider    String
  model       String
  inputTokens Int
  outputTokens Int
  costUsd     Float
  costRub     Float
  agentId     String?
  sessionId   String?
  workspaceId String?
  runId       String?
  createdAt   DateTime @default(now())

  @@index([provider, createdAt])
  @@index([workspaceId, createdAt])
  @@index([agentId, createdAt])
  @@index([runId])
}

// ============================================
// Agent Memory (short & long-term)
// JSON-backed for now; upgrade to vector(1536) via pgvector when available
// ============================================

model AgentMemory {
  id          String   @id @default(cuid())
  agentId     String
  workspaceId String?
  projectId   String?
  memoryType  String   @default("episodic") // "episodic" | "semantic" | "procedural"
  content     String                         // The memory text
  summary     String?                        // Short summary for retrieval
  metadata    String   @default("{}")        // JSON blob for extra fields
  /// embedding JSON array — replace with Unsupported("vector(1536)") after pgvector install
  embeddingJson String? @map("embedding_json")
  importance  Float    @default(0.5)         // 0-1 relevance score
  accessCount Int      @default(0)
  lastAccessedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId, workspaceId])
  @@index([agentId, memoryType])
  @@index([workspaceId, projectId])
  @@index([importance])
}

// ============================================
// RAG — Project Document Index
// ============================================

model ProjectDocument {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("general")
  source      String   @default("inline")
  projectId   String?
  workspaceId String?
  chunkCount  Int      @default(0)
  fullText    String?
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks      ProjectDocumentChunk[]

  @@index([projectId])
  @@index([workspaceId, type])
  @@index([source])
  @@index([workspaceId, createdAt])
}

model ProjectDocumentChunk {
  id          String   @id @default(cuid())
  documentId  String
  chunkIndex  Int
  content     String
  createdAt   DateTime @default(now())

  document    ProjectDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}
