// ============================================================
// ENGINE SCHEMA — @ceoclaw/engine-db
// ~25 models: platform infrastructure, auth, AI, memory, agents
//
// IMPORTANT: This file is consumed by tools/prisma-merge/index.ts
// to generate the combined schema for `prisma migrate`.
// Do NOT run `prisma generate` on this file directly.
// ============================================================

generator engineClient {
  provider = "prisma-client-js"
  output   = "../node_modules/@ceoclaw/engine-db"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

