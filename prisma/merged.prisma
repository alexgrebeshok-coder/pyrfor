  parent    ExpenseCategory?  @relation("ExpenseCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ExpenseCategory[] @relation("ExpenseCategoryTree")
  expenses  Expense[]
}

model Expense {
  id          String          @id
  projectId   String
  categoryId  String
  title       String
  description String?
  amount      Float
  currency    String          @default("RUB")
  date        DateTime
  status      String          @default("pending")
  documentUrl String?
  supplierId  String?
  taskId      String?
  equipmentId String?
  createdById String?
  oneCRef     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  equipment   Equipment?      @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  supplier    Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([categoryId])
  @@index([status])
  @@index([oneCRef])
}

model ResourceAssignment {
  id           String      @id
  taskId       String
  memberId     String?
  equipmentId  String?
  units        Float       @default(100)
  plannedHours Float?
  actualHours  Float?      @default(0)
  costRate     Float?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime    @default(now())
  task         Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member       TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  equipment    Equipment?  @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([memberId])
  @@index([equipmentId])
}

model User {
  id                 String          @id
  name               String?
  email              String?         @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  accounts           Account[]
  memberships        Membership[]
  sessions           Session[]
  preference         UserPreference?
  approvalsRequested Approval[]      @relation("ApprovalRequester")
  approvalsReviewed  Approval[]      @relation("ApprovalReviewer")

  @@index([email])
  @@index([createdAt])
}

model UserPreference {
  id                   String   @id
  userId               String   @unique
  workspaceId          String?
  compactMode          Boolean  @default(true)
  desktopNotifications Boolean  @default(true)
  soundEffects         Boolean  @default(false)
  emailDigest          Boolean  @default(true)
  aiResponseLocale     String   @default("ru")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WorkReport {
  id                         String      @id
  reportNumber               String      @unique
  projectId                  String
  authorId                   String
  reviewerId                 String?
  section                    String
  reportDate                 DateTime
  workDescription            String
  volumesJson                String      @default("[]")
  personnelCount             Int?
  personnelDetails           String?
  equipment                  String?
  weather                    String?
  issues                     String?
  nextDayPlan                String?
  attachmentsJson            String      @default("[]")
  status                     String      @default("submitted")
  reviewComment              String?
  source                     String      @default("manual")
  externalReporterTelegramId String?
  externalReporterName       String?
  submittedAt                DateTime    @default(now())
  reviewedAt                 DateTime?
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt
  reviewer                   TeamMember? @relation("WorkReport_reviewerIdToTeamMember", fields: [reviewerId], references: [id])
  author                     TeamMember  @relation("WorkReport_authorIdToTeamMember", fields: [authorId], references: [id])
  project                    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, reportDate])
  @@index([projectId, status, reportDate])
  @@index([projectId, reportDate])
  @@index([status])
  @@index([reportDate])
  @@index([reviewerId])
  @@index([authorId])
  @@index([projectId])
}

model Workspace {
  id                   String                @id
  organizationId       String
  key                  String
  name                 String
  initials             String
  description          String?
  isDefault            Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspaceMemberships WorkspaceMembership[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model WorkspaceMembership {
  id           String     @id
  workspaceId  String
  membershipId String
  role         String?
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, membershipId])
  @@index([membershipId])
}

model Approval {
  id            String    @id
  type          String // task_creation, risk_mitigation, budget_change, report_publish, ai_action
  entityType    String // task, risk, project, report, ai_run
  entityId      String?
  title         String
  description   String?
  status        String    @default("pending") // pending, approved, rejected, expired
  requestedById String?
  reviewedById  String?
  comment       String?
  metadata      String? // JSON string for type-specific data
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  expiresAt     DateTime?
  requestedBy   User?     @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy    User?     @relation("ApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([entityType, entityId])
}

model ConnectorCredential {
  id             String    @id @default(cuid())
  workspaceId    String
  connectorId    String // "google-calendar", "quickbooks", "xero", etc.
  provider       String // OAuth provider: "google", "microsoft", "yandex", "intuit", "xero"
  accessToken    String // encrypted at rest
  refreshToken   String? // encrypted at rest
  tokenExpiresAt DateTime?
  scopes         String? // comma-separated granted scopes
  accountLabel   String? // user-visible label ("My Gmail", "Work QuickBooks")
  accountEmail   String? // associated account email
  metadata       String? // JSON string for provider-specific data (realm IDs, tenant IDs)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  syncEntries ConnectorSyncEntry[]

  @@unique([workspaceId, connectorId])
  @@index([workspaceId])
  @@index([connectorId])
  @@index([provider])
}

model ConnectorSyncEntry {
  id               String    @id @default(cuid())
  credentialId     String
  direction        String // "pull" | "push"
  entityType       String // "calendar_events", "expenses", "invoices", "vendors"
  status           String    @default("running") // "running" | "completed" | "failed"
  recordsProcessed Int       @default(0)
  recordsFailed    Int       @default(0)
  error            String?
  syncToken        String? // delta sync token for incremental fetches
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  credential ConnectorCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, startedAt])
  @@index([status])
}

model AgentMessage {
  id            String   @id
  type          String
  source        String
  target        String?
  payload       String   @default("{}")
  workspaceId   String?
  runId         String?
  correlationId String?
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
  @@index([source, createdAt])
  @@index([workspaceId, createdAt])
  @@index([runId])
}

model AIRunCost {
  id           String   @id @default(cuid())
  provider     String
  model        String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  costRub      Float
  agentId      String?
  sessionId    String?
  workspaceId  String?
  runId        String?
  projectId    String?
  goalId       String?
  agentDbId    String?
  createdAt    DateTime @default(now())

  agentDb Agent? @relation(fields: [agentDbId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([workspaceId, createdAt])
  @@index([agentId, createdAt])
  @@index([runId])
  @@index([agentDbId, createdAt])
  @@index([projectId, createdAt])
}

model AgentMemory {
  id             String    @id @default(cuid())
  agentId        String
  workspaceId    String?
  projectId      String?
  memoryType     String    @default("episodic") // "episodic" | "semantic" | "procedural"
  content        String // The memory text
  summary        String? // Short summary for retrieval
  metadata       String    @default("{}") // JSON blob for extra fields
  /// embedding JSON array — replace with Unsupported("vector(1536)") after pgvector install
  embeddingJson  String?   @map("embedding_json")
  importance     Float     @default(0.5) // 0-1 relevance score
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([agentId, workspaceId])
  @@index([agentId, memoryType])
  @@index([workspaceId, projectId])
  @@index([importance])
}

model ProjectDocument {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("general")
  source      String   @default("inline")
  projectId   String?
  workspaceId String?
  chunkCount  Int      @default(0)
  fullText    String?
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks ProjectDocumentChunk[]

  @@index([projectId])
  @@index([workspaceId, type])
  @@index([source])
  @@index([workspaceId, createdAt])
}

model ProjectDocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String
  createdAt  DateTime @default(now())

  document ProjectDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model Agent {
  id                 String   @id @default(cuid())
  workspaceId        String
  definitionId       String?
  name               String
  slug               String
  role               String   @default("engineer")
  status             String   @default("idle")
  reportsToId        String?
  reportsTo          Agent?   @relation("AgentOrgChart", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports            Agent[]  @relation("AgentOrgChart")
  adapterType        String   @default("internal")
  adapterConfig      String   @default("{}")
  runtimeConfig      String   @default("{}")
  budgetMonthlyCents Int      @default(0)
  spentMonthlyCents  Int      @default(0)
  permissions        String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  apiKeys             AgentApiKey[]
  runtimeState        AgentRuntimeState?
  wakeupRequests      AgentWakeupRequest[]
  heartbeatRuns       HeartbeatRun[]
  ownedGoals          Goal[]                @relation("GoalOwner")
  taskLinks           AgentTaskLink[]
  workflowSteps       WorkflowRunStep[]
  costEvents          AIRunCost[]
  configRevisions     AgentConfigRevision[]
  secrets             AgentSecret[]
  permissionGrants    PermissionGrant[]
  deadLetterJobs      DeadLetterJob[]
  outgoingDelegations AgentDelegation[]     @relation("AgentDelegationParent")
  incomingDelegations AgentDelegation[]     @relation("AgentDelegationChild")

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([definitionId])
  @@index([reportsToId])
}

model AgentApiKey {
  id         String    @id @default(cuid())
  agentId    String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([agentId])
}

model AgentRuntimeState {
  id                  String    @id @default(cuid())
  agentId             String    @unique
  totalTokens         Int       @default(0)
  totalCostCents      Int       @default(0)
  totalRuns           Int       @default(0)
  successfulRuns      Int       @default(0)
  consecutiveFailures Int       @default(0)
  circuitState        String    @default("closed")
  circuitOpenedAt     DateTime?
  circuitOpenUntil    DateTime?
  lastRunId           String?
  lastError           String?
  lastHeartbeatAt     DateTime?
  updatedAt           DateTime  @updatedAt
  agent               Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([circuitState, circuitOpenUntil])
}

model AgentWakeupRequest {
  id             String          @id @default(cuid())
  agentId        String
  reason         String
  triggerData    String          @default("{}")
  status         String          @default("queued")
  idempotencyKey String?
  retryCount     Int             @default(0)
  maxRetries     Int             @default(3)
  availableAt    DateTime        @default(now())
  lastError      String?
  lastErrorType  String?
  createdAt      DateTime        @default(now())
  processedAt    DateTime?
  agent          Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  deadLetterJobs DeadLetterJob[]

  @@unique([agentId, idempotencyKey])
  @@index([agentId, status, createdAt])
  @@index([status, availableAt, createdAt])
}

model HeartbeatRun {
  id                       String    @id @default(cuid())
  workspaceId              String
  agentId                  String
  wakeupRequestId          String?
  status                   String    @default("queued")
  invocationSource         String    @default("on_demand")
  replayOfRunId            String?
  replayReason             String?
  replayedFromCheckpointId String?
  usageJson                String?
  resultJson               String?
  contextSnapshot          String?
  startedAt                DateTime?
  finishedAt               DateTime?
  createdAt                DateTime  @default(now())

  agent                  Agent                    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  replayOfRun            HeartbeatRun?            @relation("HeartbeatRunReplayLineage", fields: [replayOfRunId], references: [id], onDelete: SetNull)
  replayRuns             HeartbeatRun[]           @relation("HeartbeatRunReplayLineage")
  replayedFromCheckpoint HeartbeatRunCheckpoint?  @relation("HeartbeatRunReplayCheckpoint", fields: [replayedFromCheckpointId], references: [id], onDelete: SetNull)
  events                 HeartbeatRunEvent[]
  checkpoints            HeartbeatRunCheckpoint[]
  deadLetterJobs         DeadLetterJob[]
  workflowStep           WorkflowRunStep?
  outgoingDelegations    AgentDelegation[]        @relation("RunDelegationParent")
  incomingDelegations    AgentDelegation[]        @relation("RunDelegationChild")

  @@index([agentId, startedAt])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, agentId, startedAt])
  @@index([replayOfRunId])
  @@index([replayedFromCheckpointId])
}

model HeartbeatRunEvent {
  id        String       @id @default(cuid())
  runId     String
  seq       Int
  type      String
  content   String
  createdAt DateTime     @default(now())
  run       HeartbeatRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([runId])
}

model HeartbeatRunCheckpoint {
  id             String         @id @default(cuid())
  runId          String
  stepKey        String
  seq            Int
  checkpointType String
  stateJson      String
  createdAt      DateTime       @default(now())
  run            HeartbeatRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  replayRuns     HeartbeatRun[] @relation("HeartbeatRunReplayCheckpoint")

  @@unique([runId, seq])
  @@index([runId])
  @@index([runId, stepKey])
}

model WorkflowTemplate {
  id             String        @id @default(cuid())
  workspaceId    String
  name           String
  slug           String
  description    String?
  version        Int           @default(1)
  definitionJson String
  status         String        @default("draft")
  createdBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  runs           WorkflowRun[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status, updatedAt])
}

model WorkflowRun {
  id                 String    @id @default(cuid())
  workflowTemplateId String
  workspaceId        String
  status             String    @default("queued")
  triggerType        String    @default("manual")
  inputJson          String    @default("{}")
  contextJson        String    @default("{}")
  resultJson         String?
  errorMessage       String?
  createdBy          String?
  startedAt          DateTime?
  finishedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  template    WorkflowTemplate  @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  steps       WorkflowRunStep[]
  delegations AgentDelegation[]

  @@index([workspaceId, status, createdAt])
  @@index([workflowTemplateId, createdAt])
}

model WorkflowRunStep {
  id             String    @id @default(cuid())
  workflowRunId  String
  nodeId         String
  name           String
  stepType       String
  seq            Int
  status         String    @default("pending")
  dependsOnJson  String    @default("[]")
  inputJson      String?
  outputJson     String?
  errorMessage   String?
  agentId        String?
  approvalId     String?
  checkpointId   String?
  heartbeatRunId String?   @unique
  attemptCount   Int       @default(0)
  maxRetries     Int       @default(1)
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workflowRun  WorkflowRun   @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  agent        Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  heartbeatRun HeartbeatRun? @relation(fields: [heartbeatRunId], references: [id], onDelete: SetNull)

  @@unique([workflowRunId, nodeId])
  @@index([workflowRunId, status, seq])
  @@index([agentId, status])
  @@index([approvalId])
}

model AgentDelegation {
  id             String    @id @default(cuid())
  workspaceId    String
  workflowRunId  String?
  workflowStepId String?
  parentAgentId  String?
  childAgentId   String
  parentRunId    String?
  childRunId     String?
  reason         String
  status         String    @default("delegated")
  metadataJson   String    @default("{}")
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  workflowRun WorkflowRun?  @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  parentAgent Agent?        @relation("AgentDelegationParent", fields: [parentAgentId], references: [id], onDelete: SetNull)
  childAgent  Agent         @relation("AgentDelegationChild", fields: [childAgentId], references: [id], onDelete: Cascade)
  parentRun   HeartbeatRun? @relation("RunDelegationParent", fields: [parentRunId], references: [id], onDelete: SetNull)
  childRun    HeartbeatRun? @relation("RunDelegationChild", fields: [childRunId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workflowRunId])
  @@index([workflowStepId])
  @@index([parentAgentId, childAgentId])
  @@index([parentRunId])
  @@index([childRunId])
}

model Goal {
  id           String          @id @default(cuid())
  workspaceId  String
  parentId     String?
  parent       Goal?           @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Goal[]          @relation("GoalHierarchy")
  title        String
  description  String?
  level        String          @default("team")
  status       String          @default("planned")
  ownerAgentId String?
  owner        Agent?          @relation("GoalOwner", fields: [ownerAgentId], references: [id], onDelete: SetNull)
  projectId    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  taskLinks    AgentTaskLink[]

  @@index([workspaceId, status])
  @@index([parentId])
  @@index([ownerAgentId])
  @@index([projectId])
}

model AgentTaskLink {
  id         String   @id @default(cuid())
  taskId     String
  agentId    String
  goalId     String?
  runId      String?
  assignedAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  goal  Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@unique([taskId, agentId])
  @@index([agentId])
  @@index([goalId])
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  authorType String
  authorId   String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model Label {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  createdAt   DateTime    @default(now())
  tasks       TaskLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
}

model AgentConfigRevision {
  id        String   @id @default(cuid())
  agentId   String
  field     String // "runtimeConfig" | "permissions" | "adapterConfig" | "role" | "name"
  oldValue  String?
  newValue  String?
  changedBy String // userId or agentId
  changedAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, changedAt])
}

model AgentSecret {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String?
  key         String
  encValue    String // AES-256-GCM encrypted
  iv          String // Initialization vector (hex)
  tag         String // Auth tag (hex)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agent       Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([agentId])
}

model PermissionGrant {
  id        String   @id @default(cuid())
  agentId   String
  resource  String // "project", "task", "risk", "expense", "report", "*"
  action    String // "read", "write", "delete", "*"
  scope     String   @default("") // optional projectId or "*" for all
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, resource, action, scope])
  @@index([agentId])
}

model DeadLetterJob {
  id              String              @id @default(cuid())
  workspaceId     String
  agentId         String
  wakeupRequestId String?
  runId           String?
  reason          String
  errorType       String
  errorMessage    String
  payloadJson     String              @default("{}")
  attempts        Int                 @default(0)
  status          String              @default("open")
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())
  agent           Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  wakeupRequest   AgentWakeupRequest? @relation(fields: [wakeupRequestId], references: [id], onDelete: SetNull)
  run             HeartbeatRun?       @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([agentId, createdAt])
  @@index([runId])
  @@index([wakeupRequestId])
}
